---
profile: production

exclude_paths:
  - collections/
  - .github/
  - molecule/
  - "*.md"
  - common/tasks/csb_detect.yml
  - common/tasks/csb-examples-*.yml
  - common/tasks/container-provision.yml
  - common/tasks/container-provision-play.yml
  - common/tasks/csb-failure-handler.yml

skip_list:
  - yaml[line-length]  # yamllint handles this with 140 char limit
