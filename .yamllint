---
extends: default

ignore: |
  collections/
  .github/

rules:
  line-length:
    max: 140
  truthy:
    check-keys: false
    ignore: '.github/workflows/*.yml'
  comments:
    min-spaces-from-content: 1
  comments-indentation: false
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  braces:
    max-spaces-inside: 1
  brackets:
    max-spaces-inside: 1
