# {{ ansible_managed }}

[theme]
theme = "dracula"

[icons]
icons = "awesome6"

[[block]]
block = "time"
format = " $timestamp.datetime(f:'%a %d %b %H:%M') "
interval = 30

[[block]]
block = "battery"
format = " $percentage $time "
full_format = " $percentage "

[[block]]
block = "cpu"
format = " $utilization "
interval = 5

[[block]]
block = "memory"
format = " $mem_used_percents "
interval = 5

[[block]]
block = "sound"
format = " $volume "
show_volume_when_muted = true

[[block]]
block = "disk_space"
path = "/"
format = " $available "
interval = 60

[[block]]
block = "net"
format = " $speed_down.eng(prefix:K) $speed_up.eng(prefix:K) "
interval = 5
