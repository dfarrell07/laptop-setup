# {{ ansible_managed }}
# Audit rules for sensitive file access monitoring

# Exclusion rules (MUST come before watch rules — first-match wins)
-a never,exit -F exe=/usr/bin/ssh-agent -k exclude-ssh-agent
-a never,exit -F exe=/usr/bin/gpg-agent -k exclude-gpg-agent

# Write/attribute changes on frequently-accessed sensitive paths
-w {{ real_user_home }}/.ssh/ -p wa -k claude-sensitive-write
-w {{ real_user_home }}/.gnupg/ -p wa -k claude-sensitive-write
-w {{ real_user_home }}/.kube/config -p rwa -k claude-sensitive-write

# Read access on rarely-accessed high-value files
-w {{ real_user_home }}/.aws/ -p r -k claude-sensitive-read
-w {{ real_user_home }}/.vault_pass -p r -k claude-sensitive-read
-w {{ real_user_home }}/.claude/.credentials.json -p r -k claude-sensitive-read
-w {{ real_user_home }}/.config/containers/auth.json -p r -k claude-sensitive-read
-w {{ real_user_home }}/.config/gcloud/ -p r -k claude-sensitive-read
-w {{ real_user_home }}/.config/gh/ -p r -k claude-sensitive-read
-w {{ real_user_home }}/.config/acli/ -p r -k claude-sensitive-read
-w {{ real_user_home }}/.docker/config.json -p r -k claude-sensitive-read
-w {{ real_user_home }}/.netrc -p r -k claude-sensitive-read
-w /etc/sudoers -p wa -k privilege-escalation
-w /etc/sudoers.d/ -p wa -k privilege-escalation
-w /etc/ssh/sshd_config -p wa -k privilege-escalation
-w /etc/ssh/sshd_config.d/ -p wa -k privilege-escalation

# System identity and authentication files
-w /etc/passwd -p wa -k identity-change
-w /etc/shadow -p wa -k identity-change
-w /etc/group -p wa -k identity-change
-w /etc/pam.d/ -p wa -k auth-config

# Persistence mechanisms (system)
-w /etc/cron.d/ -p wa -k persistence
-w /etc/crontab -p wa -k persistence
-w /etc/systemd/system/ -p wa -k persistence
-w /var/spool/cron/ -p wa -k persistence

# User-level persistence
-w {{ real_user_home }}/.config/systemd/user/ -p wa -k user-persistence
-w {{ real_user_home }}/.config/autostart/ -p wa -k user-persistence
-w {{ real_user_home }}/.config/environment.d/ -p wa -k user-persistence
-w {{ real_user_home }}/.zshrc -p wa -k shell-persistence
-w {{ real_user_home }}/.zshenv -p wa -k shell-persistence
-w {{ real_user_home }}/.bashrc -p wa -k shell-persistence
-w {{ real_user_home }}/.local/bin/ -p wa -k user-persistence

# Audit infrastructure protection
-w /etc/audit/ -p wa -k audit-config
-w /sbin/auditd -p x -k audit-tools
-w /sbin/auditctl -p x -k audit-tools

# Make rules immutable (requires reboot to change)
-e 2
