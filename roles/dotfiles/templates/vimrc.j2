" {{ ansible_managed }}

set nocompatible
set tabstop=2
set shiftwidth=2
set expandtab
set autoindent
set smartindent
set number
set ruler
set showcmd
set incsearch
set hlsearch
set ignorecase
set smartcase
set history=5000
set undolevels=1000
set backspace=indent,eol,start
set clipboard=unnamedplus
set spell
syntax on
filetype plugin indent on

" Restore cursor position
autocmd BufReadPost * if line("'\"") > 1 && line("'\"") <= line("$") | exe "normal! g'\"" | endif
