# {{ ansible_managed }}

Host *
    VisualHostKey yes
    HashKnownHosts yes
    AddKeysToAgent yes

Host github.com gh gist
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_sk
    IdentitiesOnly yes
    ControlMaster auto
{% if ansible_system | default('Linux') == 'Linux' %}
    ControlPath /run/user/%i/ssh/%r@%h-%p
{% else %}
    ControlPath ~/.ssh/sockets/%r@%h-%p
{% endif %}
    ControlPersist 120

{% if profile == 'work' %}
Host internal-git
    HostName internal-git.example.com
    User git
    IdentityFile ~/.ssh/id_rsa_redhat
    IdentitiesOnly yes
{% endif %}
