# {{ ansible_managed }}

Host *
    VisualHostKey yes
    HashKnownHosts yes
    IdentitiesOnly yes
    AddKeysToAgent confirm
    KexAlgorithms {% if dotfiles_ssh_kex_pq_enabled | default(false) %}mlkem768x25519-sha256,sntrup761x25519-sha512,{% endif %}curve25519-sha256
    ControlMaster auto
{% if ansible_system | default('Linux') == 'Linux' %}
    ControlPath /run/user/%i/ssh/%r@%h-%p
{% else %}
    ControlPath ~/.ssh/sockets/%r@%h-%p
{% endif %}
    ControlPersist 120

Host github.com gh gist
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_sk
    IdentitiesOnly yes
    PubkeyAcceptedAlgorithms sk-ssh-ed25519@openssh.com,sk-ssh-ed25519-cert-v01@openssh.com

{% if profile == 'work' and dotfiles_internal_git_host | default('') not in ['', 'internal-git.example.com'] %}
Host internal-git
    HostName {{ dotfiles_internal_git_host }}
    User git
    IdentityFile ~/.ssh/id_rsa_redhat
    IdentitiesOnly yes
{% endif %}
